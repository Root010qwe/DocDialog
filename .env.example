# ============================================================
# DocDialog — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=docdialog
POSTGRES_PASSWORD=docdialog_secret
POSTGRES_DB=docdialog
DATABASE_URL=postgresql+asyncpg://docdialog:docdialog_secret@postgres:5432/docdialog

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# --- LLM Provider: "ollama" or "openai" ---
LLM_PROVIDER=ollama

# Ollama — runs natively on host (brew services start ollama), not in Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b

# OpenAI (optional, set LLM_PROVIDER=openai to use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Embeddings ---
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024

# --- Re-ranker ---
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
STORAGE_PATH=/app/storage

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:80
